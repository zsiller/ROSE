# Generated by run_mcmc.py -- do not edit by hand unless you know why.

environment
  tabular_data
    tabular_data_file 'sod_tabular.dat'

method
  bayes_calibration queso
    chain_samples = 5000 seed = 12345
    export_chain_points_file 'sod_chain.dat'
    adaptive_metropolis
    proposal_covariance
      file 'prop_cov.dat'
        matrix

variables
  uniform_uncertain 4
    descriptors   'p_high'  'p_low'  'rho_high'  'rho_low'
    lower_bounds   50000.0   5000.0    0.5        0.075
    upper_bounds  150000.0  15000.0    1.5       0.17
    initial_point 100000.0  10000.0    1.00        0.125

interface
  fork
    analysis_drivers = 'sod_driver.sh'
    parameters_file = 'params.in'
    results_file    = 'results.out'

responses
  calibration_terms = 18
    calibration_data_file = 'sod_obs.dat'
      freeform
      num_experiments = 1
      variance_type = 'scalar'
  no_gradients
  no_hessians
