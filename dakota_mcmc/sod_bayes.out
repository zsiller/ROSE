    export_chain_points_file 'sod_chain.dat'
    adaptive_metropolis
    proposal_covariance
      file 'prop_cov.dat'
        matrix

variables
  uniform_uncertain 4
    descriptors   'p_high'  'p_low'  'rho_high'  'rho_low'
