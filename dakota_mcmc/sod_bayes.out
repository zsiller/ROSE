interface
  fork
    analysis_drivers = 'sod_driver.sh'
    parameters_file = 'params.in'
    results_file    = 'results.out'

responses
  calibration_terms = 18
    calibration_data_file = 'sod_obs.dat'
      freeform
      num_experiments = 1
      variance_type = 'scalar'
  no_gradients
  no_hessians

